# Copier ce fichier vers .env et compléter les valeurs
# Le vrai .env n'est PAS versionné (cf. .gitignore)

# Clé Hugging Face : créer un token "read" sur https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_token_here

# Modèle (NLLB-200 par défaut)
HUGGINGFACE_MODEL=facebook/nllb-200-distilled-600M
