# Copy this file to .env and fill in the values
# The real .env is NOT versioned (see .gitignore)

# Optional email for the MyMemory API
# Without it, the daily quota is 5,000 characters per IP (anonymous mode)
# With it, the quota is lifted to ~50,000 words per day
# No registration or verification required, any valid email is accepted
MYMEMORY_EMAIL=
