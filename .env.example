# Copy this file to .env and fill in the values.
# The real .env is NOT versioned (see .gitignore).

# Path to the Google Cloud service account JSON key file.
# Generate one in Google Cloud Console > IAM & Admin > Service Accounts.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json

# Google Cloud project ID (visible at the top of the Cloud Console).
GOOGLE_CLOUD_PROJECT=your-project-id-here
